9️⃣ Run Job Hourly

@Scheduled(cron = "0 0 * * * *")
public void runJob() throws Exception {

    JobParameters params = new JobParametersBuilder()
            .addLong("time", System.currentTimeMillis())
            .toJobParameters();

    jobLauncher.run(csvImportJob, params);
}


